        <mxCell id="note" value="Baseline intentionally keeps ECS private, exposes only the ALB, uses GitHub OIDC instead of static AWS keys, and stores Terraform state in S3." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#64748b;align=left;spacingLeft=24;" vertex="1" parent="1">

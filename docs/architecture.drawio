<mxfile host="app.diagrams.net">
  <diagram name="Gatus ECS Platform" id="gatus-ecs-platform">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="&lt;b&gt;Gatus ECS Platform&lt;/b&gt;&lt;br&gt;Current Terraform baseline: GitHub OIDC CI/CD, ECR image delivery, public HTTPS ALB, private ECS Fargate tasks, NAT egress, and CloudWatch application logs." style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontColor=#0f172a;fontSize=14;align=left;" vertex="1" parent="1">
          <mxGeometry x="54" y="28" width="980" height="62" as="geometry"/>
        </mxCell>

